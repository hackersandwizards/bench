#!/usr/bin/env bash
# Update brew, antidote plugins, language toolchains and global packages.
set -u

# shellcheck source-path=SCRIPTDIR
# shellcheck source=_lib.sh
. "$(dirname "$0")/_lib.sh"

run "Homebrew update"     brew update
run "Homebrew upgrade"    brew upgrade
run "Homebrew cleanup"    brew cleanup -s

if [[ -f "$ANTIDOTE_SH" ]]; then
  run "Antidote plugins" zsh -c "source '$ANTIDOTE_SH' && antidote update"
  rm -f "$REPO_ROOT/plugins.zsh" "$REPO_ROOT/plugins-post.zsh"
  ok "Antidote static bundles invalidated (regenerate on next shell)"
fi
have rustup   && run "Rust toolchain"   rustup update

if have gem; then
  run "RubyGems system"   gem update --system
  run "RubyGems all"      gem update
  run "RubyGems cleanup"  gem cleanup
fi

have pipx && run "pipx apps" pipx upgrade-all
have uv   && run "uv tools" uv tool upgrade --all

_pip_managed_names() {
  # Names of pip-managed installs (have a RECORD file).
  # Brew-installed packages skip RECORD, so this filters them out.
  python3 -c 'import importlib.metadata as m
print("\n".join(d.metadata["Name"] for d in m.distributions() if d.read_text("RECORD")))' 2>/dev/null
}

_pip_global_upgrade() {
  local managed; managed=$(_pip_managed_names)
  [[ -z "$managed" ]] && return 0
  pip list --outdated --format=json 2>/dev/null \
    | jaq -r '.[].name' \
    | rg -ixFf <(printf '%s\n' "$managed") \
    | xargs -r pip install --upgrade
}

_pip_user_upgrade() {
  pip list --user --outdated --format=json 2>/dev/null \
    | jaq -r '.[].name' \
    | xargs -r pip install --user --upgrade
}

have pip && run "Python pip globals"   _pip_global_upgrade
have pip && run "Python pip user-site" _pip_user_upgrade

if have sdk; then
  run "SDKMAN selfupdate" sdk selfupdate
  run "SDKMAN update"     sdk update
fi

if have bun; then
  run "Bun runtime"       bun upgrade
  run "Bun globals"       bun -g update --latest
fi

have npm-check && \
  run "npm globals" env NPM_CHECK_INSTALLER=npm npm-check --global --update --save-exact

step "Done"
