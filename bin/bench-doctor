#!/usr/bin/env bash
# Health check for the dotfiles setup.
set -u

# shellcheck source-path=SCRIPTDIR
# shellcheck source=_lib.sh
. "$(dirname "$0")/_lib.sh"

echo "=== Environment ==="
if [[ -n "${ZSH_SETTINGS_DIR:-}" ]]; then
  ok "ZSH_SETTINGS_DIR=$ZSH_SETTINGS_DIR"
else
  warn "ZSH_SETTINGS_DIR not set in current shell (only set by init.zsh)"
fi

echo
echo "=== Required tools ==="
# antidote is a zsh function (sourced from brew), not a PATH binary
check "antidote" test -f "$ANTIDOTE_SH"
for cmd in starship zoxide fzf eza bat fd rg gh glab git delta lazygit jaq xh; do
  check "$cmd" command -v "$cmd"
done

echo
echo "=== Optional tools ==="
for cmd in atuin direnv stow gitleaks shellcheck claude; do
  check "$cmd" command -v "$cmd"
done

echo
echo "=== Stow symlinks ==="
for rel in "${STOW_FILES[@]}"; do
  if [[ -L "$HOME/$rel" ]]; then
    ok "$rel -> $(readlink "$HOME/$rel")"
  elif [[ -e "$HOME/$rel" ]]; then
    warn "$rel: real file (not Stow-managed)"
  else
    warn "$rel: missing"
  fi
done

echo
echo "=== Repo state ==="
hp=$(hooks_path)
if [[ "$hp" == ".githooks" ]]; then
  ok "core.hooksPath = .githooks"
else
  warn "core.hooksPath = $hp (run install.sh to fix)"
fi
if [[ -f "$REPO_ROOT/secrets.zsh" ]]; then
  ok "secrets.zsh present"
else
  warn "secrets.zsh missing (optional)"
fi

echo
echo "=== Git auth ==="
for tool in gh glab; do
  if "$tool" auth status >/dev/null 2>&1; then
    ok "$tool auth ok"
  else
    warn "$tool auth not configured"
  fi
done

echo
echo "=== Startup time ==="
# bash 5.3+ exposes $EPOCHREALTIME (microsecond float, no fork). Strip the dot to
# get an integer microseconds count, then divide.
start=${EPOCHREALTIME/./}
zsh -i -c exit >/dev/null 2>&1
end=${EPOCHREALTIME/./}
echo "  zsh -i -c exit took $(( (end - start) / 1000 ))ms"
