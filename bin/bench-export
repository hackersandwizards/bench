#!/usr/bin/env bash
# Refresh package inventories (Brewfile + docs/) and sync home/ from $HOME.
set -u

# shellcheck source-path=SCRIPTDIR
# shellcheck source=_lib.sh
. "$(dirname "$0")/_lib.sh"

DOCS="$REPO_ROOT/docs"
HOME_DIR="$REPO_ROOT/home"

mkdir -p "$DOCS"

# Run "$@" capturing stdout to $1; only overwrite the destination on success
# so a failed command leaves the previous snapshot intact (no empty files).
dump_to() {
  local out="$1"; shift
  local tmp="$out.tmp"
  if "$@" > "$tmp" 2>/dev/null; then
    mv "$tmp" "$out"
    ok "${out##*/}"
  else
    rm -f "$tmp"
    warn "${out##*/} failed"
  fi
}

# --- Brewfile drift check (never auto-overwrite: cask/mas entries are aspirational
# fresh-install targets, not always present locally; `brew bundle dump --force`
# would silently delete them). Report missing leaves so they can be added by hand.
if have brew; then
  step "Brewfile drift"
  declared="$(grep -E '^brew "' "$REPO_ROOT/Brewfile" | sed -E 's/^brew "([^"]+)".*/\1/' | sort -u)"
  missing="$(comm -23 <(brew leaves | sort -u) <(printf '%s\n' "$declared"))"
  if [[ -z "$missing" ]]; then
    ok "Brewfile in sync with brew leaves"
  else
    warn "Installed leaves missing from Brewfile — add by hand:"
    printf '%s\n' "$missing" | sed 's/^/    /'
  fi
fi

# SDKMAN's `sdk` is a shell function, not a binary — source its init so the
# `sdk current` snapshot below can see it (`have sdk` is false otherwise).
SDKMAN_INIT="$HOME/.sdkman/bin/sdkman-init.sh"
if [[ -s "$SDKMAN_INIT" ]]; then
  set +u
  # shellcheck disable=SC1090
  source "$SDKMAN_INIT"
  set -u
fi

# --- docs/ snapshots (replayed by install.sh, offline-readable) ---
# Each tool is its own subprocess and stat-bound — fan out, then `wait`.
step "docs/ snapshots"
if have brew; then
  dump_to "$DOCS/brew-taps.txt"   brew tap    &
  dump_to "$DOCS/brew-leaves.txt" brew leaves &
  dump_to "$DOCS/brews.txt"       brew list   &
fi
have bun   && dump_to "$DOCS/buns.txt"  bun pm -g list             &
have gem   && dump_to "$DOCS/gems.txt"  gem list                   &
have pip   && dump_to "$DOCS/pip.txt"   pip freeze                 &
have uv    && dump_to "$DOCS/uv.txt"    uv tool list               &
have npm   && dump_to "$DOCS/npms.txt"  npm list -g --depth=0      &
have cargo && dump_to "$DOCS/cargo.txt" cargo install --list       &
have sdk   && dump_to "$DOCS/sdks.txt"  sdk current                &
have mix   && dump_to "$DOCS/mix.txt"   mix archive                &
wait
[[ -f "$HOME/.gradle/gradle.properties" ]] \
  && cp "$HOME/.gradle/gradle.properties" "$DOCS/gradle.properties" \
  && ok "gradle.properties"

# --- home/ sync: copy real $HOME files back into repo, skip Stow symlinks ---
step "home/ sync (Symlinks → skip, real files → copy back)"
for rel in "${STOW_FILES[@]}"; do
  src="$HOME/$rel"
  dst="$HOME_DIR/$rel"
  if [[ ! -e "$src" ]]; then
    warn "$rel: not in \$HOME, skipping"
    continue
  fi
  if [[ -L "$src" ]]; then
    continue
  fi
  mkdir -p "$(dirname "$dst")"
  if [[ -f "$dst" ]] && cmp -s "$src" "$dst"; then
    ok "$rel: identical"
  else
    cp "$src" "$dst" && ok "$rel: copied"
  fi
done

step "Done"
