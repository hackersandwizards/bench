[include]
	path = ~/.gitconfig.local
[color]
	ui = auto
	diff = true
[alias]
	st = status -sb
	co = checkout
	pu = pull --rebase --all
	ps = push
	all = "!/bin/zsh -fc 'emulate -L zsh; /opt/homebrew/bin/fd -H -0 \"^\\.git$\" . --prune | while IFS= read -r -d \"\" gitpath; do repo=${gitpath:h}; print -r -- \"${repo:a}\"; git -C \"$repo\" \"$@\"; done' --"
	integrate = "!f() { test -n \"$1\" || { echo >&2 \"usage: git integrate <branch>\"; exit 2; }; test \"$(git merge-base HEAD \"$1\")\" = \"$(git rev-parse HEAD)\" || { echo >&2 \"Not up-to-date; refusing to merge, rebase first!\"; exit 1; }; git merge --no-ff --edit \"$1\"; }; f"
	unstage = reset HEAD
	undo-commit = reset --soft
	b = branch
	c = commit
	p = pull
	ll = log --graph --oneline --decorate --color --all --pretty=format:'%C(yellow)%h|%Cred%ad|%Cblue%an%Creset%C(auto)%d %s' --date=short
[core]
	autocrlf = input
	pager = delta
	excludesfile = ~/.gitignore_global
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	light = true
	line-numbers = true
	syntax-theme = GitHub
[push]
	default = simple
	autoSetupRemote = true
[pull]
	rebase = true
[merge]
	conflictstyle = diff3
[init]
	defaultBranch = main
[commit]
	template = ~/.commitTemplate.txt
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gitlab.com"]
	helper =
	helper = !/opt/homebrew/bin/glab auth git-credential
