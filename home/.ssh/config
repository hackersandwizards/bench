Host *
  IgnoreUnknown UseKeychain,AddKeysToAgent
  UseKeychain yes
  AddKeysToAgent yes
  IdentitiesOnly yes
  HashKnownHosts yes
  StrictHostKeyChecking ask
  ForwardAgent no
  ForwardX11 no
  ServerAliveInterval 300
  ServerAliveCountMax 2
  Compression yes
  ControlMaster auto
  ControlPath ~/.ssh/control/%C
  ControlPersist 1800

Host github.com gitlab.com
  User git
