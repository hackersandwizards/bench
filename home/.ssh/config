Host *
  IgnoreUnknown UseKeychain,AddKeysToAgent
  UseKeychain yes
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_rsa
  HashKnownHosts yes
  ServerAliveInterval 300
  ServerAliveCountMax 2
  Compression yes
  TCPKeepAlive yes
  ControlMaster auto
  ControlPath ~/.ssh/control/%C
  ControlPersist 1800
  SendEnv GIT_*
  GSSAPIAuthentication no

Host github.com
  User git
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_rsa

Host gitlab.com
  User git
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_rsa
