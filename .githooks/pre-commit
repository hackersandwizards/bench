#!/usr/bin/env bash
# Block commits that contain secrets. Requires `gitleaks` (brew install gitleaks).
set -e

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks not installed — skipping scan" >&2
  echo "  install: brew install gitleaks" >&2
  exit 0
fi

gitleaks git --staged --redact --no-banner
